# Supabase configuration.
# Copy this file to .env.local and fill in the values from your Supabase
# project. .env.local is gitignored and must never be committed.

# Project URL. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (new Supabase API keys). Client-side; safe in the browser
# because access is constrained by Row Level Security.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (new Supabase API keys). Server-only; bypasses RLS.
# NEVER expose this to the browser and NEVER prefix it with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=
